            },
            "accordion_row_DUAa3P": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "¿Puedo recibir una muestra antes de producir?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_awMmay": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Sí. Podemos enviar muestras de producto <strong>previo pago</strong>. Si posteriormente confirmas el pedido, <strong>el coste de la muestra se descuenta del pedido final</strong>.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",

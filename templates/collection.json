                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_qNwTeF": {
                  "type": "text",
                  "settings": {
                    "text": "<p>El pedido mínimo depende de cada producto. Trabajamos tanto proyectos pequeños como producciones corporativas de mayor volumen. </p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",

{% comment %}
  Flexible Layout Section con nested_container que permite bloques hijos (text, image, button)
{% endcomment %}

{%- liquid
  assign grid_columns = section.settings.column_count | default: 3
  assign grid_rows = section.settings.rows_count | default: 3
  assign layout_type = section.settings.layout
  assign is_grid = false
  assign is_flex_grid = false

  if layout_type == "grid"
    assign is_grid = true
  elsif layout_type == "flex-grid"
    assign is_flex_grid = true
  endif
-%}

{% style %}
  .flexible-video-block {
    position: relative;
  }
  .copilot-video-wrapper {
    position: relative;
  }

  .copilot-video-wrapper video {
    width: 100%;
    height: 100%;
    display: block;
  }

  .copilot-video-poster {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    z-index: 2;
    cursor: pointer;
  }

  /* ocultar cuando reproduce */
  .copilot-video-wrapper.is-playing .copilot-video-poster {
    display: none;
  }

  /* botón play */
  .copilot-video-card__play {
    position: absolute;
    z-index: 3;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  .copilot-video-card__play{
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 70px;
    height: 70px;
    border-radius: 50%;
    background: rgba(0,0,0,.5);
    color: white;
    border: none;
    font-size: 22px;
    cursor: pointer;
  }
{% endstyle %}

<section class="custom-flex-layout {{ section.settings.custom_class }}" style="
  {% if is_grid %}
    display: grid;
    grid-template-columns: repeat({{ grid_columns }}, 1fr);
    grid-template-rows: repeat({{ grid_rows }}, auto);
    grid-auto-flow: dense;
  {% elsif is_flex_grid %}
    display: flex;
    flex-wrap: wrap;
    --columns: {{ grid_columns }};
    --gap: {{ section.settings.gap }};
  {% else %}
    display: {{ layout_type }};
    flex-direction: {{ section.settings.flex_direction }};
  {% endif %}
  justify-content: {{ section.settings.justify_content }};
  align-items: {{ section.settings.align_items }};
  background-color: {{ section.settings.background_color }};
  border: {{ section.settings.border }};
  width: {{ section.settings.width }};
  height: {{ section.settings.height }};
  padding: {{ section.settings.padding }};
  margin: {{ section.settings.margin }};
  gap: {{ section.settings.gap }};">

  {%- assign containers = section.blocks | where: "type", "container" -%}

  {%- for container in containers -%}
    {%- liquid
      assign grid_position = container.settings.grid_position | default: "auto/auto"
      assign position_parts = grid_position | split: '/'
      assign grid_column = position_parts[0] | default: 'auto'
      assign grid_row = position_parts[1] | default: 'auto'
      
      if is_flex_grid
        assign flex_position = grid_position | split: '/' | join: '-'
        assign flex_order = container.settings.flex_order | default: 0
      endif
    -%}

    {% assign container_link = container.settings.link %}

    {% if container_link != blank %}
      <a 
        href="{{ container_link }}"
        id="{{ container.settings.container_name }}"
        class="layout-block layout-block--container layout-block--link"
        {% if container.settings.link_new_tab %}
          target="_blank"
          rel="noopener"
        {% endif %}
        style="
          display: {{ container.settings.layout }};
          flex-direction: {{ container.settings.flex_direction }};
          justify-content: {{ container.settings.justify_content }};
          align-items: {{ container.settings.align_items }};
          background-color: {{ container.settings.background_color }};
          border: {{ container.settings.border }};
          width: {{ container.settings.width }};
          height: {{ container.settings.height }};
          padding: {{ container.settings.padding }};
          margin: {{ container.settings.margin }};
          gap: {{ container.settings.gap }};
          text-decoration:none;
          color:inherit;
          {% if is_grid %}
            grid-column: {{ grid_column }};
            grid-row: {{ grid_row }};
          {% elsif is_flex_grid %}
            flex: 0 0 calc((100% / var(--columns)) - var(--gap));
            min-width: calc((100% / var(--columns)) - var(--gap));
            order: {{ flex_order }};
          {% endif %}
        "
      >
    {% else %}
      <div 
        id="{{ container.settings.container_name }}"
        class="layout-block layout-block--container"
        style="
          display: {{ container.settings.layout }};
          flex-direction: {{ container.settings.flex_direction }};
          justify-content: {{ container.settings.justify_content }};
          align-items: {{ container.settings.align_items }};
          background-color: {{ container.settings.background_color }};
          border: {{ container.settings.border }};
          width: {{ container.settings.width }};
          height: {{ container.settings.height }};
          padding: {{ container.settings.padding }};
          margin: {{ container.settings.margin }};
          gap: {{ container.settings.gap }};
          {% if is_grid %}
            grid-column: {{ grid_column }};
            grid-row: {{ grid_row }};
          {% elsif is_flex_grid %}
            flex: 0 0 calc((100% / var(--columns)) - var(--gap));
            min-width: calc((100% / var(--columns)) - var(--gap));
            order: {{ flex_order }};
          {% endif %}
        "
      >
    {% endif %}

      {% render 'copilot-block', container: container, blocks: section.blocks %}

    {% if container_link != blank %}
      </a>
    {% else %}
      </div>
    {% endif %}

  {%- endfor -%}

</section>

{% javascript %}
  document.addEventListener("DOMContentLoaded", function () {

    document.querySelectorAll(".flexible-video-block").forEach(block => {

      const video = block.querySelector("video");
      const btn = block.querySelector(".copilot-video-card__play");
      const poster = block.querySelector(".copilot-video-poster");

      if (!video) return;

      video.muted = true;
      video.playsInline = true;
      video.preload = "metadata";

      function playFullVideo() {
        video.currentTime = 0;
        video.muted = false;
        video.controls = true;
        block.classList.add("playing");

        if (btn) btn.style.display = "none";
        //if (poster) poster.style.opacity = "0";
        if (poster) poster.style.display = "none";

        video.play().catch(() => {});
      }

      function hoverPreviewStart() {
          if (window.innerWidth <= 768) return;
          if (block.classList.contains("playing")) return;

          video.muted = true;
          video.controls = false;

          if (poster) poster.style.display = "none";
          //if (btn) btn.style.display = "none";

          video.play().catch(() => {});
      }

      function hoverPreviewStop() {
          if (window.innerWidth <= 768) return;
          if (block.classList.contains("playing")) return;

          video.pause();
          video.currentTime = 0;

          if (poster) poster.style.display = "";
          if (btn) btn.style.display = "";
      }

      if (btn) {
        btn.addEventListener("click", function (e) {
          e.preventDefault();
          playFullVideo();
        });
      }

      block.addEventListener("mouseenter", hoverPreviewStart);
      block.addEventListener("mouseleave", hoverPreviewStop);

      video.addEventListener("ended", function () {
          if (block.classList.contains("playing")) {
              block.classList.remove("playing");
              video.controls = false;
              video.muted = true;
              video.currentTime = 0;

              if (btn) btn.style.display = "";
              if (poster) poster.style.display = "";
          }
      });

    });
  });
{% endjavascript %}


<script>
    document.addEventListener('DOMContentLoaded', () => {
        if (window.innerWidth > 1024) {
            document.querySelectorAll('.marquee-track').forEach(track => {
                const speed = 0.6;
                const direction = track.dataset.direction;
                const originalHTML = track.innerHTML;

                let y = 0;
                let loopHeight = 0;

                function setup() {
                    // Duplicar hasta cubrir 3x el alto visible
                    while (track.scrollHeight < track.parentElement.offsetHeight * 3) {
                        track.innerHTML += originalHTML;
                    }
                }
                function calculate() {
                    loopHeight = track.scrollHeight / 2;

                    // Posición inicial correcta
                    if (direction === 'down') {
                        y = -loopHeight;
                    } else {
                        y = 0;
                    }
                }
                function animateUp() {
                    y -= speed;

                    if (y <= -loopHeight) {
                        y += loopHeight;   // 🔥 wrap circular estable
                    }

                    track.style.transform = `translateY(${y}px)`;
                    requestAnimationFrame(animateUp);
                }
                function animateDown() {
                    y += speed;

                    if (y >= 0) {
                        y -= loopHeight;   // 🔥 wrap circular estable
                    }

                    track.style.transform = `translateY(${y}px)`;
                    requestAnimationFrame(animateDown);
                }
                // Init
                setup();
                calculate();

                if (direction === 'up') {
                    animateUp();
                } else {
                    animateDown();
                }
                // Recalcular en resize
                window.addEventListener('resize', () => {
                    calculate();
                });

            });
        }
    });
</script>


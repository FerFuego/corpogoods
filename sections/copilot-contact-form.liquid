{% style %}

  .section-contact-hero {
    font-family: Poppins, sans-serif;
    max-width: 1230px;
    margin: 120px auto;
    padding: 40px;
    background: #f5f5f5;
    border-radius: 15px;
  }

  .contact-hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 60px;
    align-items: center;
  }

  /* Image */
  .contact-hero-image {
    border-radius: 15px;
  }

  .contact-hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Content */
  .contact-hero-content h2 {
    font-family: Poppins;
    font-weight: 700;
    font-size: 30px;
    line-height: 40px;
    letter-spacing: 0;
    text-align: center;
    color: #171717;
    max-width: 420px;
    margin: 0 auto 20px;
  }

  .contact-hero-content p {
    font-family: Poppins;
    font-weight: 400;
    font-size: 16px;
    line-height: 26px;
    letter-spacing: 0px;
    text-align: center;
    color: #979798;
    max-width: 440px;
    margin: 0 auto 20px;
  }

  /* Form */
  .contact-form input,
  .contact-form select {
    width: 100%;
    border: none;
    border-bottom: 1px solid #d0d0d0;
    border-radius: 0;
    padding: 10px 0;
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    margin-bottom: 20px;
    background: transparent;
  }

  .contact-form input[type="checkbox"] {
    width: 20px;
    border: none;
    border-bottom: 1px solid #d0d0d0;
    padding: 10px 0;
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    margin-bottom: 3px;
    background: transparent;
  }

  .contact-form input:focus,
  .contact-form select:focus {
    outline: none;
    border-color: #171717;
  }

  .contact-form__checkbox {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: #777;
    margin: 20px 0;
  }

  .contact-form__button {
    display: block;
    background: #ff7a00;
    color: #ffffff;
    border: 0;
    border-radius: 15px;
    padding: 4px 40px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    margin: 0 auto;

    font-family: Poppins;
    font-weight: 400;
    font-size: 20px;
    line-height: 40px;
    letter-spacing: 0px;
    text-align: center;
  }
  .contact-form__button:hover {
    opacity: 0.9;
  }
  .contact-hero-image__title-mobile {
    display: none;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .contact-hero-grid {
      grid-template-columns: 1fr;
      gap: 0px;
    }
    .section-contact-hero {
      background-color: #fff;
      padding: 40px 20px;
      margin: 0;
    }
    .contact-hero-image {
      padding: 0;
    }
    .contact-hero-image__title-mobile {
      display: block;
      font-family: Poppins;
      font-weight: 700;
      font-size: 25px;
      line-height: 30px;
      letter-spacing: 0;
      text-align: center;
      color: #171717;
      max-width: 100%;
      margin: 0 auto;
      z-index: 2;
      position: relative;
    }
    .contact-hero-content__title {
      display: none;
    }
    .contact-hero-image img {
    }
  }
{% endstyle %}

{%- liquid
  assign has_app_form_block = false

  for block in section.blocks
    if block.type == '@app'
      assign has_app_form_block = true
      break
    endif
  endfor
-%}

<section class="section-contact-hero" id="contacto">

  <div class="contact-hero-grid">

    <!-- Image -->
    <div class="contact-hero-image">
      {% if section.settings.image != blank %}
        <h2 class="contact-hero-image__title-mobile">{{ section.settings.title }}</h2>
        <img 
          src="{{ section.settings.image | image_url: width: 1000 }}"
          alt=""
          loading="lazy"
        >
      {% endif %}
    </div>

    <!-- Content -->
    <div class="contact-hero-content">

      <h2 class="contact-hero-content__title">{{ section.settings.title }}</h2>
      <p>{{ section.settings.text }}</p>

      {% if has_app_form_block %}
        <div class="contact-hero-app-blocks">
          {% for block in section.blocks %}
            {% if block.type == '@app' %}
              <div class="contact-hero-app-block" {{ block.shopify_attributes }}>
                {% render block %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% else %}
        {% form 'contact', class: 'contact-form' %}
          <input type="text" name="contact[name]" placeholder="Nombre y apellidos" required>
          <input type="email" name="contact[email]" placeholder="Email profesional" required>
          <input type="text" name="contact[company]" placeholder="Empresa">

          <select name="contact[context]">
            <option value="">¿Para qué necesitas el regalo?</option>
            <option>Bienvenida de empleados</option>
            <option>Evento corporativos</option>
            <option>Regalo a clientes</option>
            <option>Kits de marca</option>
            <option>otro contexto</option>
          </select>

          <label class="contact-form__checkbox">
            <input type="checkbox" required>
            Estoy de acuerdo con la política de privacidad
          </label>

          <button type="submit" class="contact-form__button">
            {{ section.settings.button_text }}
          </button>
        {% endform %}
      {% endif %}


    </div>

  </div>

</section>

{% schema %}
{
  "name": "Copilot Contact Form",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Hablemos de cómo representar bien tu marca"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texto",
      "default": "Cuéntanos el contexto y te ayudamos a elegir un regalo corporativo con criterio, coherente y a la altura de tu empresa."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto botón",
      "default": "Hablar con un experto"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Copilot Contact Form"
    }
  ]
}
{% endschema %}
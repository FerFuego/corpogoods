    line-height: 40px;
    letter-spacing: 0;
    color: #171717;
}
.cart-drawer__inner .cart-items__details>*+*, .cart-items__bundle li {
    margin-block-start: 0;
}
.cart-drawer__inner .quantity-selector-wrapper {
    display: none !important;
}
.cart-drawer__inner .cart-items__table-row {
